---
layout: null
permalink: /partners/poke-korean.json
sitemap: false
---
{% assign partner = site.data.partners.poke-korean %}
{% assign tagged = site.posts | where_exp: "p", "p.partners contains 'poke-korean'" %}
{% if tagged.size > 0 %}
  {% assign partner_posts = tagged %}
{% else %}
  {% assign partner_posts = site.posts %}
{% endif %}
{
  "partner": {
    "slug": "poke-korean",
    "name": {{ partner.name | jsonify }},
    "url": {{ partner.url | jsonify }},
    "tagline": {{ partner.tagline | jsonify }},
    "description": {{ partner.description | strip_newlines | jsonify }}
  },
  "generated_at": {{ site.time | date_to_xmlschema | jsonify }},
  "mode": {% if tagged.size > 0 %}"filtered"{% else %}"all-posts-fallback"{% endif %},
  "count": {{ partner_posts.size }},
  "posts": [
    {% for post in partner_posts %}
    {
      "title": {{ post.title | jsonify }},
      "url": {{ post.url | prepend: site.url | jsonify }},
      "date": {{ post.date | date_to_xmlschema | jsonify }},
      "description": {{ post.description | jsonify }},
      "cover_image": {% if post.cover_image %}{{ post.cover_image | prepend: site.url | jsonify }}{% else %}null{% endif %},
      "tags": {{ post.tags | jsonify }},
      "read_time": {{ post.read_time | default: 0 }}
    }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ]
}
